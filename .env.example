# Product Compass — environment template. Copy to .env.local and fill in real values.
# Committed to git on purpose (no secrets here).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic (server-side only)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Adzuna (server-side only — job ingestion, Stage 8). Register at
# https://developer.adzuna.com to get free keys.
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# AI budget guard (server-side only — both optional, defaults shown).
# Stage 16: the monthly cap is now PLAN-BASED. Free users get FREE_BRIEFS_PER_MONTH
# live briefs; Pro users are unlimited (still bounded by the hourly per-IP backstop).
# AI_MONTHLY_LIMIT (Stage 11) is RETIRED — FREE_BRIEFS_PER_MONTH replaces it.
FREE_BRIEFS_PER_MONTH=3
AI_IP_HOURLY_LIMIT=10

# Stage 15 — email notifications via Resend (server-side only, NEVER NEXT_PUBLIC_*).
# RESEND_API_KEY: from resend.com → API Keys. Also used as the Supabase Auth SMTP
# password (see docs/SIGNIN_UNBLOCK.md) so magic-link/OTP email actually delivers.
RESEND_API_KEY=your-resend-api-key
# From address on a VERIFIED Resend domain (test mode reaches only your own email).
# TODO(v3): current value `Product Compass <onboarding@resend.dev>` is Resend's
# shared sandbox — it ONLY delivers to your own Resend signup email. To email real
# users, buy a domain, verify it in Resend (SPF+DKIM+DMARC), then change RESEND_FROM
# to no-reply@mail.<yourdomain>. No code change — src/lib/email.ts reads it from env.
RESEND_FROM=Product Compass <no-reply@mail.yourdomain.com>
# Canonical public base URL — used to build email deep links + unsubscribe URLs
# server-side. Safe to expose (it's just the site URL). Falls back to the request
# origin if unset.
NEXT_PUBLIC_APP_URL=https://product-compass-lilac.vercel.app

# Stage 12 — daily cron ingestion (server-side only, NEVER NEXT_PUBLIC_*).
# CRON_SECRET: Vercel sends it as `Authorization: Bearer <secret>` on cron calls.
# The route fails CLOSED if it is unset, so the endpoint can never be left open.
CRON_SECRET=your-long-random-cron-secret
# A dedicated Supabase auth user that may ONLY write `roles` (see is_ingest_bot()
# in scripts/stage12-cron-ingestion.sql). Deliberately NOT an admin.
INGEST_BOT_EMAIL=ingest-bot@example.com
INGEST_BOT_PASSWORD=your-ingest-bot-password
