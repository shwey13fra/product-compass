# Product Compass — environment template. Copy to .env.local and fill in real values.
# Committed to git on purpose (no secrets here).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Anthropic (server-side only)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Adzuna (server-side only — job ingestion, Stage 8). Register at
# https://developer.adzuna.com to get free keys.
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# AI budget guard (Stage 11, server-side only — both optional, defaults shown).
# Monthly live-positioning quota per identity, and the hourly per-IP backstop.
AI_MONTHLY_LIMIT=15
AI_IP_HOURLY_LIMIT=10

# Stage 12 — daily cron ingestion (server-side only, NEVER NEXT_PUBLIC_*).
# CRON_SECRET: Vercel sends it as `Authorization: Bearer <secret>` on cron calls.
# The route fails CLOSED if it is unset, so the endpoint can never be left open.
CRON_SECRET=your-long-random-cron-secret
# A dedicated Supabase auth user that may ONLY write `roles` (see is_ingest_bot()
# in scripts/stage12-cron-ingestion.sql). Deliberately NOT an admin.
INGEST_BOT_EMAIL=ingest-bot@example.com
INGEST_BOT_PASSWORD=your-ingest-bot-password
